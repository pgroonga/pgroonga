require_relative "../pgroonga-package-task"

class PostgreSQL18PGroongaPackageTask < VersionedPGroongaPackageTask
  def initialize
    super("18")
  end

  def apt_targets_default
    []
  end

  def enable_ubuntu?
    [
      ["resolute", "26.04"],
    ]
  end

  def enable_yum?
    false
  end
end

task = PostgreSQL18PGroongaPackageTask.new
task.define
